<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
 xmlns:models="clr-namespace:MauiApp1.Models"
 xmlns:viewModels="clr-namespace:MauiApp1.ViewModels"
 x:DataType="viewModels:ControlPanelViewModel"
             x:Class="MauiApp1.Views.ControlPanelView"
             x:Name="this"
             Title="">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding OnAppearingCommand}" BindingContext="{Binding Source={x:Reference this}, Path=BindingContext}"/>
    </ContentPage.Behaviors>
    <VerticalStackLayout>
        <Label >
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Legtöbb szabadsággal rendelkező dolgozó: "/>
                    <Span Text="{Binding WorkerName}"/>
                </FormattedString>
            </Label.FormattedText>
        </Label>
        <Label >
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Az összes még kiadható szabadáságnapok száma: "/>
                    <Span Text="{Binding UntakenLeaveDaysCount}"/>
                </FormattedString>
            </Label.FormattedText>
        </Label>
    </VerticalStackLayout>
</ContentPage>