<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
     xmlns:models="clr-namespace:MauiApp1.Models"
     xmlns:viewModels="clr-namespace:MauiApp1.ViewModels"
     x:DataType="viewModels:UpdateWorkerViewModel"
             x:Class="MauiApp1.Views.UpdateWorkerView"
             x:Name="this"
             Title="">
    <VerticalStackLayout HorizontalOptions="Center">
        <Label>
            <Label.FormattedText>
            <FormattedString>
                <Span Text="Dolgozó neve: "/>
                <Span Text="{Binding Worker.Name}"/>
            </FormattedString>
        </Label.FormattedText>
        </Label>
        <Label>
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Maximum kivehető napok száma: "/>
                    <Span Text="{Binding MaxNumberOfLEaveDays}"/>
                </FormattedString>
            </Label.FormattedText>
        </Label>
        <Entry Text="{Binding Input}"/>
        <Button Text="Mentés" Command="{Binding OnSaveCommand}" WidthRequest="200" />
    </VerticalStackLayout>
</ContentPage>